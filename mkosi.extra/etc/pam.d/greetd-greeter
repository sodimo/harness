#%PAM-1.0
# Harness: full session setup for direct user login (no greeter UI)

# Auth: set wayland session type, permit without password
auth       required     pam_env.so
auth       required     pam_env.so conffile=/usr/share/greetd/greetd-spawn.pam_env.conf
auth       required     pam_permit.so

# Account: permit
account    required     pam_permit.so

# Password: deny (no password changes through greeter)
password   required     pam_deny.so

# Session: SELinux context transition + full systemd integration
session    required     pam_selinux.so close
session    required     pam_loginuid.so
session    required     pam_selinux.so open
session    optional     pam_keyinit.so force revoke
session    required     pam_namespace.so
session    include      system-auth
-session   optional     pam_gnome_keyring.so auto_start
session    include      postlogin
